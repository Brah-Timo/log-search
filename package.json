{
  "name": "log-search",
  "version": "1.0.0",
  "description": "Search through 50GB log files in under a second. 1M lines/sec indexed search engine for DevOps engineers.",
  "keywords": [
    "log",
    "search",
    "grep",
    "logs",
    "devops",
    "cli",
    "nginx",
    "apache",
    "kubernetes",
    "fast-search",
    "log-analysis",
    "log-viewer",
    "inverted-index"
  ],
  "author": {
    "name": "log-search contributors",
    "email": "hello@log-search.dev",
    "url": "https://log-search.dev"
  },
  "license": "MIT",
  "homepage": "https://log-search.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Brah-Timo/log-search"
  },
  "bugs": {
    "url": "https://github.com/Brah-Timo/log-search/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "log-search": "./bin/log-search.js",
    "lsearch": "./bin/log-search.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "dev": "ts-node src/cli/main.ts",
    "start": "node dist/cli/main.js",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "benchmark": "node scripts/benchmark.js",
    "prepublishOnly": "npm run build && npm test",
    "clean": "rimraf dist",
    "generate:logs": "node scripts/generate-large-log.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.3",
    "inquirer": "^8.2.6",
    "chokidar": "^3.6.0",
    "fast-glob": "^3.3.2",
    "fuse.js": "^7.0.0",
    "lru-cache": "^10.2.2",
    "msgpackr": "^1.10.1",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "node-fetch": "^2.7.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7",
    "@types/jest": "^29.5.12",
    "@types/inquirer": "^8.2.10",
    "@types/cli-progress": "^3.11.5",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/node-fetch": "^2.6.11",
    "@types/source-map-support": "^0.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5"
  }
}
